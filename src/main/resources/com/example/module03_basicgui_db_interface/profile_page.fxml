<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="295.0" prefWidth="345.0" style="-fx-background-color: f2f2f2;" stylesheets="@styling/style.css"
            xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/23.0.1"
            fx:controller="com.example.module03_basicgui_db_interface.ProfilePageController">
    <Label alignment="CENTER" contentDisplay="CENTER" layoutX="15.0" layoutY="14.0" prefHeight="55.0" prefWidth="317.0"
           stylesheets="@styling/style.css" text="Change Your Profile By Clicking Profile Picture!"
           textAlignment="CENTER" underline="true" wrapText="true">
        <font>
        <Font name="Beirut Regular" size="18.0"/>
        </font>
    </Label>
    <ImageView fx:id="profilePictureImageView" fitHeight="170.0" fitWidth="170.0" layoutX="89.0" layoutY="77.0"
               onMouseClicked="#handleImageClick" preserveRatio="true">
        <Image url="@images/profile.png"/>
    </ImageView>
    <Button layoutX="140.0" layoutY="255.0" onAction="#handleSave" prefHeight="26.0" prefWidth="65.0"
            style="-fx-background-color: #E8E8E8; -fx-border-color: black; -fx-border-width: 1.5; -fx-border-radius: 2;"
            stylesheets="@styling/style.css" text="Save">
        <font>
        <Font name="System Bold" size="13.0"/>
        </font>
    </Button>
</AnchorPane>